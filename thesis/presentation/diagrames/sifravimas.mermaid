---
config:
  theme: base
  themeVariables:
    fontSize: 22px
    primaryColor: '#e8edf2'
    primaryTextColor: '#1f2937'
    primaryBorderColor: '#9ca3af'
    lineColor: '#4b5563'
  layout: dagre
---
flowchart TB
    subgraph DEV["Kūrėjo mašina"]
        subgraph TOOLS["Kompiliavimo įrankiai"]
            Python["Python 3\nencrypt_lib.py"]
            NDK["Android NDK\n+ CMake"]
            Gradle["Gradle + AGP"]
        end
        subgraph OUTPUT["Kompiliavimo išvestis"]
            LibA["liba.so\nlibnativecallhook.so\n(teisingas ELF)"]
            LibB["liblibb.so\n(XOR užšifruota\nnegaliojantis ELF)"]
        end
    end
    APK["APK paketas"]

    NDK -->|"kompiliuoja .cpp → .so"| LibA
    NDK -->|"kompiliuoja .cpp → .so"| LibB
    Python -->|"XOR šifruoja vietoje"| LibB
    Gradle -->|"supakuoja"| APK
    OUTPUT -->|"įtraukiama į"| Gradle

    style Python fill:#fffbeb,stroke:#d97706,color:#1f2937
    style NDK fill:#dbeafe,stroke:#6b7280,color:#1f2937
    style Gradle fill:#dbeafe,stroke:#6b7280,color:#1f2937
