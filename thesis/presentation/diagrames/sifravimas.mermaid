    style LibB fill:#fde8d8,stroke:#9ca3af,color:#1f2937
    style APK fill:#d1fae5,stroke:#059669,color:#065f46
    style TOOLS fill:#eff6ff,stroke:#bfdbfe
    style OUTPUT fill:#fafaf9,stroke:#d1d5db
    style DEV fill:#f9fafb,stroke:#9ca3af
