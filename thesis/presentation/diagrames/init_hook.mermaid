---
config:
  theme: base
  themeVariables:
    fontSize: 22px
    primaryColor: '#e8edf2'
    primaryTextColor: '#1f2937'
    primaryBorderColor: '#9ca3af'
    lineColor: '#4b5563'
  layout: dagre
---
flowchart LR
    Ctor["__attribute__\n((constructor))"]

    subgraph ELF["libnativecallhook.so — ELF segmentai"]
        text[".text"]
        rodata[".rodata"]
        init_array[".init_array"]
        plt[".plt"]
        got[".got.plt"]
    end

    Linker["Bionic linkeris\nukrauna biblioteką\nprieš Java onCreate()"]

    init_hook["init_hook()"]
    BHInit["bytehook_init()\nBYTEHOOK_MODE_AUTOMATIC"]
    BHHook["bytehook_hook_all()\n__loader_dlopen → hooked_dlopen"]
    PLTMod["PLT / GOT\nlentelių modifikavimas"]
    Result["Visi dlopen() kvietimai\n→ hooked_dlopen()"]

    Ctor -->|"kompiliatorius įrašo į"| init_array
    Linker -->|"vykdo"| init_array
    init_array -->|"iškviečia"| init_hook
    init_hook --> BHInit
    BHInit --> BHHook
    BHHook --> PLTMod
    PLTMod --> Result

    style Ctor fill:#dbeafe,stroke:#6b7280,color:#1f2937
    style text fill:#f3f4f6,stroke:#d1d5db,color:#9ca3af
    style rodata fill:#f3f4f6,stroke:#d1d5db,color:#9ca3af
    style init_array fill:#fde68a,stroke:#d97706,color:#78350f
    style plt fill:#f3f4f6,stroke:#d1d5db,color:#9ca3af
    style got fill:#f3f4f6,stroke:#d1d5db,color:#9ca3af
    style Linker fill:#f3f4f6,stroke:#9ca3af,color:#1f2937
    style init_hook fill:#dbeafe,stroke:#6b7280,color:#1f2937
    style BHInit fill:#fffbeb,stroke:#d97706,color:#1f2937
    style BHHook fill:#fffbeb,stroke:#d97706,color:#1f2937
    style PLTMod fill:#fde68a,stroke:#d97706,color:#78350f
    style Result fill:#d1fae5,stroke:#059669,color:#065f46
    style ELF fill:#fafaf9,stroke:#d1d5db
